// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String    @id @default(uuid())
  email             String?   @unique
  password          String?
  name              String
  avatarUrl         String?
  isGuest           Boolean   @default(false)
  firstName         String?
  lastName          String?
  isEmailVerified   Boolean   @default(false)
  emailVerifiedAt   DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  verificationTokens  VerificationToken[]
  passwordResetTokens PasswordResetToken[]
  groupsCreated       SplitGroup[]
  groupMemberships    GroupMember[]
  splitsPaid          Split[]
  splitShares         SplitShare[]
  budgetSetting       BudgetSetting?
  budgetCategories    BudgetCategory[]
  transactions        Transaction[]
  merchantCategories  MerchantCategory[]
  groupCategoriesCreated GroupCategory[]

  @@map("users")
}

model VerificationToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("verification_tokens")
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("password_reset_tokens")
}

model SplitGroup {
  id         String   @id @default(uuid())
  name       String
  emoji      String   @default("💸")
  createdBy  String
  creator    User     @relation(fields: [createdBy], references: [id])
  inviteCode String   @unique
  createdAt  DateTime @default(now())

  members         GroupMember[]
  splits          Split[]
  groupCategories GroupCategory[]

  @@map("split_groups")
}

model GroupCategory {
  id        String     @id @default(uuid())
  groupId   String
  group     SplitGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  name      String
  icon      String     @default("📦")
  createdBy String
  creator   User       @relation(fields: [createdBy], references: [id])
  createdAt DateTime   @default(now())

  @@unique([groupId, name])
  @@map("group_categories")
}

model GroupMember {
  id       String     @id @default(uuid())
  groupId  String
  group    SplitGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  userId   String
  user     User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  isAdmin  Boolean    @default(false)
  joinedAt DateTime   @default(now())

  @@map("group_members")
}

model Split {
  id          String     @id @default(uuid())
  groupId     String
  group       SplitGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  title       String
  description String?
  category    String
  totalAmount Decimal
  paidBy      String
  payer       User       @relation(fields: [paidBy], references: [id])
  splitType   String
  createdAt   DateTime   @default(now())

  shares       SplitShare[]
  transactions Transaction[]

  @@map("splits")
}

model SplitShare {
  id         String  @id @default(uuid())
  splitId    String
  split      Split   @relation(fields: [splitId], references: [id], onDelete: Cascade)
  userId     String
  user       User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  amount     Decimal
  isSettled  Boolean @default(false)

  @@map("split_shares")
}

model BudgetSetting {
  id                 String   @id @default(uuid())
  userId             String   @unique
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  monthlyIncome      Decimal  @default(0)
  monthlySavingsGoal Decimal  @default(0)
  updatedAt          DateTime @updatedAt

  @@map("budget_settings")
}

model BudgetCategory {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name         String
  icon         String
  monthlyLimit Decimal
  isFixed      Boolean  @default(true)

  transactions       Transaction[]
  merchantCategories MerchantCategory[]

  @@map("budget_categories")
}

model Transaction {
  id          String          @id @default(uuid())
  userId      String
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  amount      Decimal
  type        String
  categoryId  String?
  category    BudgetCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  splitId     String?
  split       Split?          @relation(fields: [splitId], references: [id], onDelete: SetNull)
  // merchantKey is a normalised merchant identifier (e.g. "nikhil sharma",
  // "swiggy") that lets us auto-categorise future transactions to the same
  // payee. Stored lowercase, trimmed. Null when no merchant is known.
  merchantKey String?
  date        DateTime        @default(now())

  @@index([userId, merchantKey])
  @@map("transactions")
}

/// Per-user mapping of normalised merchant name → budget category. Populated
/// when the user explicitly assigns a category to a transaction with a
/// merchantKey; consulted on every new auto-imported transaction so future
/// SMS from the same payee land in the same category automatically.
model MerchantCategory {
  id          String         @id @default(uuid())
  userId      String
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  merchantKey String
  categoryId  String
  category    BudgetCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@unique([userId, merchantKey])
  @@map("merchant_categories")
}

model RevokedToken {
  id        String   @id @default(uuid())
  jti       String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("revoked_tokens")
}
